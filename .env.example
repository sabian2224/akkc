# Copy this file to .env.local and fill in the values.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.

# --- Supabase ---
# Project URL (Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Service role key — SECRET, server-side only. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- App ---
# Public base URL of the deployed app, used to build admin links in emails.
# e.g. http://localhost:3000 in development.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Email (SMTP) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
# "true" only for implicit TLS (port 465); otherwise leave false (STARTTLS).
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
# "From" address shown on outgoing mail.
SMTP_FROM="AKKC <no-reply@example.com>"
# Inbox that receives the "new application" notification with the admin link.
ADMIN_EMAIL=admin@example.com
